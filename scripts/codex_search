#!/usr/bin/env bash

set -euo pipefail

model="${CODEX_SEARCH_MODEL:-gpt-5.4-mini}"
reasoning="${CODEX_SEARCH_REASONING:-low}"

usage() {
  cat <<'EOF'
Usage:
  codex_search [codex exec options] [PROMPT]
  codex_search [codex exec options] - < prompt.md

Defaults to gpt-5.4-mini with low reasoning for search, scraping, extraction,
and source cleanup. Override CODEX_SEARCH_MODEL and CODEX_SEARCH_REASONING only
when delegating complete research that requires synthesis by a top model.

Examples:
  codex_search -C /path/to/repo -o /tmp/sources.md - < search-prompt.md
  CODEX_SEARCH_MODEL=gpt-5.4 CODEX_SEARCH_REASONING=high \
    codex_search -o /tmp/research.md - < prompt.md
EOF
}

if [[ "${1:-}" == '-h' || "${1:-}" == '--help' ]]; then
  usage
  exit 0
fi

if [[ $# -eq 0 ]]; then
  usage >&2
  printf '\n[codex_search] error: provide a prompt argument or pass - to read stdin\n' >&2
  exit 2
fi

printf '[codex_search] model=%s reasoning=%s search=enabled ephemeral=true\n' \
  "$model" "$reasoning" >&2

if ! codex \
  --search \
  --model "$model" \
  -c model_reasoning_effort="$reasoning" exec \
  --ephemeral \
  "$@"
then
  printf '[codex_search] error: Codex search failed\n' >&2
  exit 1
fi
