#!/usr/bin/env bash
#
# keepwarm — keeps the OAuth tokens of Claude and Codex alive in the sannux
# *persistent* container.
#
# The ephemeral containers (sannux_ephemeral) copy the persistent home and,
# at the end, `rm -rf` it — throwing away any token refresh they performed.
# Because of refresh-token rotation (only one is valid at a time), an
# ephemeral that refreshes and then discards invalidates the persistent token.
#
# This script avoids that by periodically pinging each agent via `sannux run`
# (which mounts the persistent home read-write), keeping the *access token*
# always fresh. That way the ephemerals always copy a valid token and never
# need to refresh on their own.
#
# INTERVAL must be shorter than the access-token lifetime, so that some ping
# always lands near expiry and triggers the refresh that gets persisted.

set -uo pipefail

LOG_FILE="$HOME/dotfiles/scripts/keepwarm.log"

INTERVAL="3h"        # Default: 3h  — time between pings (< access-token lifetime)
INITIAL_RUN=1        # Default: 1   — 1 = ping once shortly after starting
INITIAL_DELAY="10s"  # Default: 10s — wait before the first ping

# Kill any previous instance. The [k] trick avoids matching the pkill itself.
pkill -9 -f "[k]eepwarm" >/dev/null 2>&1 || true

log() {
  printf '%s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$1" >> "$LOG_FILE"
}

trap 'log "TERM/INT received, exiting"; exit 0' TERM INT

maybe_sleep() {
  [ -n "${1:-}" ] && sleep "$1"
}

run_ping() {
  # $1 = label for the log; remaining args = the command to pipe the prompt to.
  local label="$1"; shift
  local out err rc errfile
  # Keep stdout (the agent's answer) and stderr (banners, progress, container
  # noise) apart: codex dumps a verbose, ANSI-colored banner on stderr that
  # would otherwise pollute every successful ping. We only want the answer on
  # success, and the diagnostics only when something actually fails.
  errfile="$(mktemp)"
  out="$(echo "Testing. Answer with true" | "$@" 2>"$errfile")"
  rc=$?
  err="$(cat "$errfile")"; rm -f "$errfile"

  # A failed ping does NOT kill the loop — just log it and retry next cycle.
  if [ "$rc" -eq 0 ]; then
    log "$label ping ok: $(printf '%s' "$out" | tr '\n' ' ')"
  else
    log "$label ping FAILED (rc=$rc): $(printf '%s' "$err" | tr '\n' ' ')"
  fi
}

ping_agents() {
  run_ping claude sannux run \
    claude-code -p - --no-session-persistence --model haiku --effort low
  run_ping codex sannux run \
    codex exec --yolo - --ephemeral --model gpt-5.4-mini -c model_reasoning_effort=low --color never
}

reload_loop() {
  if [ "$INITIAL_RUN" -eq 1 ]; then
    maybe_sleep "$INITIAL_DELAY"
    ping_agents
  fi

  while :; do
    maybe_sleep "$INTERVAL"
    ping_agents
  done
}

log "keepwarm started (interval=$INTERVAL, initial_run=$INITIAL_RUN, initial_delay=$INITIAL_DELAY)"
reload_loop &
disown
