#!/usr/bin/env bash

set -euo pipefail

MODEL="qwen3.6:35b-a3b-bf16"

printf "Current Directory: %b\n" "$(pwd)"
printf "Model: %b\n" "${MODEL}"

declare PROMPT
PROMPT="Verify the modified files in the current directory using Git. "
PROMPT+="Create organized and well-documented commit messages, using the " 
PROMPT+="conventional commit style, and commit the files with clear commit messages. " 
PROMPT+="Use the message body for longer messages, if necessary. The language is English. " 
PROMPT+="Do not touch, edit, or delete files. Your only task is to document what was done "
PROMPT+="and confirm the changes. "

MODEL="${MODEL}" printf "%b" "${PROMPT}\n" | ollama_os

