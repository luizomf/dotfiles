#!/usr/bin/env bash

set -euo pipefail

CURDIR="$(pwd)"

: "${PROJECTS_DIR:?Set PROJECTS_DIR before running sannux}"

sannux_dir="${PROJECTS_DIR%/}/sannux"

cd "$sannux_dir" || exit 1
template="${1:?'Usage: sannux_ephemeral <template_name>'}"

cd "templates/$template" || exit 1
shift

# shellcheck disable=SC1091
source .env

# EPHEMERAL
tmp_home="$(mktemp -d)"
persistent_home="${AGENT_HOME_PATH}"
tmp_workspace="$CURDIR"

# THE HOME WILL BE REMOVED AFTER DONE
trap 'rm -rf "$tmp_home"' EXIT

mkdir -p "$tmp_workspace"
test -d "$persistent_home"
cp -a "$persistent_home/." "$tmp_home/"

docker compose run \
  -v "$tmp_workspace:/workspace" \
  -v "$tmp_home:/home/agent" \
  --rm -T agent "${@}"
