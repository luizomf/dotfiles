#!/usr/bin/env bash

set -euo pipefail

# Examples
# echo "Testing. Please, answer: 'OK'" | sannux_ephemeral codex exec --ephemeral --yolo 2>/dev/null
# echo "Testing. Please, answer: 'OK'" | sannux_ephemeral codex-ollama exec --ephemeral --yolo 2>/dev/null
# echo "Testing. Please, answer: 'OK'" | sannux_ephemeral claude-code --no-session-persistence --dangerously-skip-permissions -p - 2>/dev/null
# echo "Testing. Please, answer: 'OK'" | sannux_ephemeral claude-ollama --no-session-persistence --dangerously-skip-permissions -p - 2>/dev/null

CURDIR="${CURDIR:-"$(pwd)"}"

: "${PROJECTS_DIR:?Set PROJECTS_DIR before running sannux}"

sannux_dir="${PROJECTS_DIR%/}/sannux"

cd "$sannux_dir" || exit 1
template="${1:?'Usage: sannux_ephemeral <template_name>'}"

cd "templates/$template" || exit 1

# shellcheck disable=SC1091
source .env

# EPHEMERAL
tmp_home="$(mktemp -d)"
persistent_home="${AGENT_HOME_PATH}"
tmp_workspace="$CURDIR"

# THE HOME WILL BE REMOVED AFTER DONE
trap 'rm -rf "$tmp_home"' EXIT

mkdir -p "$tmp_workspace"
test -d "$persistent_home"

case $template in
  codex|codex-ollama)
    mkdir -p "${tmp_home}/.codex"
    cp "$persistent_home/.codex/config.toml" "$tmp_home/.codex/config.toml"

    if [[ -f "$persistent_home/.codex/auth.json" ]]; then
      cp "$persistent_home/.codex/auth.json" "$tmp_home/.codex/auth.json"
    fi
    shift
    ;;
  claude-code)
    mkdir -p "${tmp_home}"
    cp -a "$persistent_home"/. "$tmp_home"/
    shift
    ;;
  claude-ollama)
    mkdir -p "${tmp_home}"
    cp -rf "$persistent_home/.claude/" "$tmp_home/.claude/"

    if [[ -f "$persistent_home/.claude.json" ]]; then
      cp "$persistent_home/.claude.json" "$tmp_home/.claude.json"
    fi

    shift
    ;;
  *)
    printf "%b\n" "Template not configured"
    exit 1
esac

declare -a docker_cmd=(
  docker compose run
  -v "$tmp_workspace:/workspace"
  -v "$tmp_home:/home/agent"
  --rm
)

# STDIN
if [[ ! -t 0 ]]; then
  docker_cmd+=(-T agent)

  "${docker_cmd[@]}" "${@}"
  exit $?
fi

docker_cmd+=(-it agent)
"${docker_cmd[@]}" "${@}"
exit $?
