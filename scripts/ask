#!/usr/bin/env zsh

ASK_SCRIPT_NAME="${0:t}"

usage() {
  cat <<EOF
Usage:
  ${ASK_SCRIPT_NAME} [options] [-- <backend args...>]

Prompt input:
  -p, --prompt <text>   Use <text> as the prompt
  --editor              Write the prompt in nvim
  stdin                 Read the prompt from a pipe or heredoc

Options:
  -m, --model <model>   Model alias/name (default: \${MODEL:-qwen3.6:35b-a3b-mxfp8})
  -t, --tts             Enable TTS
  -l, --lang <lang>     TTS language: a/en -> voiceen, p/pt -> voicept (default: a)
  -v, --voice <value>   Legacy option; a/p/en/pt also select the TTS language
  -h, --help            Show this help

Models:
  haiku, sonnet, opus, codex, gemini, or any Ollama model
  Use provider/model to pick a specific model, e.g.:
    codex/gpt-5.4-codex-spark, gemini/gemini-3.1-pro-preview, claude/sonnet

Passthrough:
  Everything after -- is forwarded to the selected command.

Examples:
  ${ASK_SCRIPT_NAME} -p "Explain closures in Python"
  ${ASK_SCRIPT_NAME} --editor
  echo "Explain closures in Python" | ${ASK_SCRIPT_NAME}
  ${ASK_SCRIPT_NAME} --model gpt-oss:20b -- --verbose --think=high <<'PROMPT'
Explain closures in Python
PROMPT
  ${ASK_SCRIPT_NAME} -m codex -p "Refactor this" -- -a never -s workspace-write
  ${ASK_SCRIPT_NAME} -m gemini -p "Summarize this text" -- --help
  ${ASK_SCRIPT_NAME} -m llama3.3:70b -p "Write a haiku"
  ${ASK_SCRIPT_NAME} -p "Clean this answer" -t -v p
EOF
}

main() {
  emulate -L zsh
  setopt nounset pipefail

  # shellcheck disable=SC1091
  . "${HOME}/dotfiles/zsh/config/functions"
  # shellcheck disable=SC1091
  . "${HOME}/dotfiles/zsh/config/aliases"

  local model="${MODEL:-qwen3.6:35b-a3b-mxfp8}"
  local prompt=""
  local editor=0
  local tts_lang="a"
  local tts_voice="af_heart"
  local sys_prompt=""
  local full_prompt=""
  local answer=""
  local tts_cmd=""

  integer tts=0
  integer tts_lang_set=0

  local -a extra_args=()
  local -a cmd=()
  local -a claude_cmd=(
    claude
    --no-session-persistence
    --disable-slash-commands
    --effort low
  )
  local -a gemini_cmd=(
    gemini
    -s
    -m auto
  )
  local -a codex_cmd=(
    codex
  )
  local -a ollama_cmd=(
    ollama
    run
    --nowordwrap
    --think=high
  )

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--model)
        model="${2:?"$1 requires a value"}"
        shift 2
        ;;
      -p|--prompt)
        prompt="${2:-}"
        shift 2
        ;;
      -t|--tts)
        tts=1
        shift
        ;;
      -l|--lang)
        tts_lang="${2:?"$1 requires a value"}"
        tts_lang_set=1
        shift 2
        ;;
      -v|--voice)
        tts_voice="${2:?"$1 requires a value"}"
        shift 2
        ;;
      --editor)
        editor=1
        shift 1
        ;;
      -h|--help)
        usage
        return 0
        ;;
      --)
        shift
        extra_args=("$@")
        break
        ;;
      *)
        print -u2 -- "Unknown argument: $1"
        print -u2 -- "Use -- to forward extra args to the selected command."
        return 1
        ;;
    esac
  done

  if (( ! tts_lang_set )); then
    case "${tts_voice:l}" in
      a|am|american|en|en-us|english|us|p|br|brazilian|pt|pt-br|portuguese)
        tts_lang="$tts_voice"
        ;;
    esac
  fi

  if [[ $editor -eq 1 ]]; then
    nvim -c 'startinsert' /tmp/ask_dotfiles_script_question.tmp

    if [[ ! -f "/tmp/ask_dotfiles_script_question.tmp" ]]; then
      print -u2 -- "Empty editor output. Either use --editor or -p <prompt>."
      return 1
    fi

    prompt="$(cat /tmp/ask_dotfiles_script_question.tmp)"
    rm /tmp/ask_dotfiles_script_question.tmp
  fi

  [[ -z "$prompt" && ! -t 0 ]] && prompt="$(cat)"

  if [[ -z "$prompt" ]]; then
    print -u2 -- "Missing prompt. Use -p <prompt>, --editor, or pipe text into stdin."
    return 1
  fi

  local provider=""
  local model_name=""

  if [[ "$model" == */* ]]; then
    provider="${model%%/*}"
    model_name="${model#*/}"
  fi

  case "${provider:-$model}" in
    haiku)
      cmd=("${claude_cmd[@]}" --model haiku -p - "${extra_args[@]}")
      ;;
    sonnet)
      cmd=("${claude_cmd[@]}" --model sonnet -p - "${extra_args[@]}")
      ;;
    opus)
      cmd=("${claude_cmd[@]}" --model opus -p - "${extra_args[@]}")
      ;;
    claude)
      cmd=("${claude_cmd[@]}" --model "$model_name" -p - "${extra_args[@]}")
      ;;
    codex)
      [[ -n "$model_name" ]] && codex_cmd[2]="$model_name"
      cmd=("${codex_cmd[@]}" -m "${model_name}" "${extra_args[@]}" "exec")
      ;;
    gemini)
      [[ -n "$model_name" ]] && gemini_cmd[4]="$model_name"
      cmd=("${gemini_cmd[@]}" "${extra_args[@]}")
      ;;
    ollama)
      cmd=("${ollama_cmd[@]}" "$model_name" "${extra_args[@]}")
      ;;
    *)
      cmd=("${ollama_cmd[@]}" "$model" "${extra_args[@]}")
      ;;
  esac

  if (( tts )); then
    [[ -r "${HOME}/dotfiles/prompts/clean_answer.md" ]] || {
      print -u2 -- "Prompt file not found: ${HOME}/dotfiles/prompts/clean_answer.md"
      return 1
    }

    command -v pbcopy >/dev/null 2>&1 || {
      print -u2 -- "pbcopy not found."
      return 1
    }

    case "${tts_lang:l}" in
      a|am|american|en|en-us|english|us)
        tts_cmd="voiceen"
        ;;
      p|br|brazilian|pt|pt-br|portuguese)
        tts_cmd="voicept"
        ;;
      *)
        print -u2 -- "Unknown TTS language: ${tts_lang}. Use a/en or p/pt."
        return 1
        ;;
    esac

    command -v "$tts_cmd" >/dev/null 2>&1 || {
      print -u2 -- "$tts_cmd not found."
      return 1
    }

    print -- "MODO TTS"

    sys_prompt="$(< "${HOME}/dotfiles/prompts/clean_answer.md")"
    full_prompt="${sys_prompt}"$'\n\n'"${prompt}"

    if ! answer="$(print -r -- "$full_prompt" | "${cmd[@]}")"; then
      print -u2 -- "Algo deu errado. O modelo engasgou."
      return 1
    fi

    print -r -- "$answer"
    print -r -- "$answer" | pbcopy
    print -r -- "$answer" | "$tts_cmd"
    return $?
  fi

  if ! print -r -- "$prompt" | "${cmd[@]}"; then
    print -u2 -- "Algo deu errado. O modelo engasgou."
    return 1
  fi
}

main "$@"

# agent: do not remove the next line
# vim: set filetype=sh :
