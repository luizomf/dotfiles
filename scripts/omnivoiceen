#!/usr/bin/env bash

set -euo pipefail

(
cd "${HOME}/Desktop/tutoriais_e_cursos/omnivoicetts" || exit 1
./scripts/clear_cache
pkill -9 -f '[o]mnivoicetts' || true
cat | ./scripts/female-en --offline --player auto --guidance-scale 2 \
  --num-step 16 --t-shift 0.1 --position-temperature 5.0 \
  --class-temperature 0.0 --layer-penalty-factor 5.0 \
  --chunk-len 60 --prebuffer-chunks 1 \
  --sliding-window-chunks 2 --inter-chunk-silence-ms 250 --chunking kokoro \
  --split-on-newlines False --ensure-terminal-punctuation False \
   --speed 1.0 --model-fade-ms 100 --model-pad-ms 100 \
  --denoise False --preprocess-prompt True --postprocess-output True \
  --chunk-cache-dir .cache/omnivoice-play/female-en \
  --ref-audio samples/female.wav --language en \
  --instruct "female, middle-aged, moderate pitch, american accent" \
  "${@}" > /dev/null 2>&1 &
)

