# shellcheck disable=all
theme = omtheme

# Font 
font-family = JetBrains Mono
font-size = 28
# Disable Ligatures completely
font-feature = -calt
font-feature = -dlig
font-feature = -liga


# Mouse
mouse-hide-while-typing = true

# Window
gtk-single-instance = true
gtk-tabs-location = bottom
gtk-wide-tabs = false
window-padding-x = 16,8
window-padding-y = 4,4
window-padding-balance = true
window-decoration = true
macos-titlebar-style = native
window-theme = ghostty
background-opacity = 1
background-blur = false

# Novo atalho: Minimiza a janela em vez de usar o toggle_quick_terminal
# O AltTab detecta perfeitamente janelas minimizadas
# keybind = global:cmd+grave_accent=minimize

# Other
# copy-on-select = clipboard
# shell-integration-features = cursor,sudo,no-title
cursor-style = block
cursor-style-blink = true

# Binds Command + ` to toggle the Quick Terminal globally
# keybind = global:cmd+grave_accent=toggle_quick_terminal
